<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Banana Crunch – Keripik Pisang Rumahan</title>
<link href="https://fonts.googleapis.com/css2?family=Fredoka+One&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --yellow:   #F5C518;
    --yellow-d: #D4A800;
    --brown:    #3D1C02;
    --brown-m:  #6B3A10;
    --cream:    #FFF8E7;
    --orange:   #E8651A;
    --green:    #4A7C3F;
    --white:    #FFFFFF;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Nunito', sans-serif;
    background: var(--cream);
    color: var(--brown);
    overflow-x: hidden;
  }

  /* ── NAV ── */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 14px 40px;
    background: rgba(255,248,231,0.92);
    backdrop-filter: blur(10px);
    border-bottom: 2px solid var(--yellow);
  }
  .nav-logo {
    font-family: 'Fredoka One', cursive;
    font-size: 1.6rem;
    color: var(--brown);
    text-decoration: none;
    display: flex; align-items: center; gap: 8px;
  }
  .nav-logo span { color: var(--orange); }
  .nav-links { display: flex; gap: 28px; list-style: none; }
  .nav-links a {
    text-decoration: none; color: var(--brown-m);
    font-weight: 700; font-size: 0.9rem; letter-spacing: .3px;
    transition: color .2s;
  }
  .nav-links a:hover { color: var(--orange); }

  /* ── HERO ── */
  .hero {
    min-height: 100vh;
    background: linear-gradient(135deg, #FFF3C4 0%, #FFE082 40%, #FFCA28 100%);
    display: flex; align-items: center;
    padding: 120px 40px 60px;
    position: relative; overflow: hidden;
  }
  .hero-bg-dots {
    position: absolute; inset: 0;
    background-image: radial-gradient(circle, rgba(61,28,2,.08) 1.5px, transparent 1.5px);
    background-size: 28px 28px;
    pointer-events: none;
  }
  .hero-inner {
    max-width: 1100px; margin: 0 auto;
    display: grid; grid-template-columns: 1fr 1fr; gap: 60px;
    align-items: center; width: 100%;
  }
  .hero-text { position: relative; }
  .hero-eyebrow {
    display: inline-block;
    background: var(--brown);
    color: var(--yellow);
    font-size: .75rem; font-weight: 800;
    letter-spacing: 2px; text-transform: uppercase;
    padding: 5px 14px; border-radius: 100px;
    margin-bottom: 20px;
  }
  .hero-title {
    font-family: 'Fredoka One', cursive;
    font-size: clamp(3rem, 6vw, 5rem);
    line-height: 1.05;
    color: var(--brown);
    margin-bottom: 18px;
  }
  .hero-title .accent { color: var(--orange); }
  .hero-sub {
    font-size: 1.05rem; line-height: 1.7;
    color: var(--brown-m); margin-bottom: 32px;
    max-width: 480px;
  }
  .btn-primary {
    display: inline-flex; align-items: center; gap: 8px;
    background: var(--brown);
    color: var(--yellow);
    font-family: 'Fredoka One', cursive;
    font-size: 1.1rem;
    padding: 14px 32px; border-radius: 50px;
    text-decoration: none;
    box-shadow: 4px 4px 0 var(--orange);
    transition: transform .15s, box-shadow .15s;
  }
  .btn-primary:hover { transform: translate(-2px,-2px); box-shadow: 6px 6px 0 var(--orange); }

  .hero-visual {
    display: flex; justify-content: center; align-items: center;
    position: relative;
  }
  .banana-emoji-big {
    font-size: clamp(6rem, 12vw, 10rem);
    animation: float 3s ease-in-out infinite;
    filter: drop-shadow(0 20px 30px rgba(0,0,0,.15));
    position: relative; z-index: 1;
  }
  .hero-badge {
    position: absolute;
    background: var(--orange);
    color: white;
    font-family: 'Fredoka One', cursive;
    font-size: 1rem;
    padding: 10px 16px;
    border-radius: 16px;
    box-shadow: 3px 3px 0 var(--brown);
    transform: rotate(-8deg);
  }
  .hero-badge.top-right { top: 10%; right: 5%; }
  .hero-badge.bottom-left { bottom: 10%; left: 0; transform: rotate(6deg); }

  @keyframes float {
    0%,100% { transform: translateY(0) rotate(-3deg); }
    50%      { transform: translateY(-18px) rotate(3deg); }
  }

  /* ── STRIP ── */
  .strip {
    background: var(--brown);
    color: var(--yellow);
    padding: 14px 0;
    overflow: hidden;
    white-space: nowrap;
  }
  .strip-inner {
    display: inline-flex; gap: 40px;
    animation: marquee 18s linear infinite;
    font-family: 'Fredoka One', cursive;
    font-size: 1rem; letter-spacing: 1px;
  }
  @keyframes marquee { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }

  /* ── SECTION BASE ── */
  section { padding: 90px 40px; }
  .sec-label {
    font-size: .75rem; font-weight: 800; letter-spacing: 3px;
    text-transform: uppercase; color: var(--orange);
    margin-bottom: 10px;
  }
  .sec-title {
    font-family: 'Fredoka One', cursive;
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--brown);
    margin-bottom: 18px;
    line-height: 1.1;
  }
  .sec-body { font-size: 1rem; line-height: 1.8; color: var(--brown-m); max-width: 680px; }
  .centered { text-align: center; }
  .centered .sec-body { margin: 0 auto; }

  /* ── ABOUT ── */
  #tentang { background: var(--white); }
  .about-grid {
    max-width: 1100px; margin: 0 auto;
    display: grid; grid-template-columns: 1fr 1fr; gap: 70px;
    align-items: center;
  }
  .about-img-wrap {
    background: linear-gradient(145deg, #FFECB3, #FFD54F);
    border-radius: 24px;
    border: 3px solid var(--yellow-d);
    padding: 40px;
    text-align: center;
    box-shadow: 6px 6px 0 var(--brown);
    font-size: 5rem;
  }
  .about-img-wrap p {
    font-family: 'Fredoka One', cursive;
    font-size: 1.4rem; color: var(--brown);
    margin-top: 12px;
  }
  .value-list { margin-top: 28px; display: flex; flex-direction: column; gap: 14px; }
  .value-item {
    display: flex; align-items: flex-start; gap: 12px;
    background: var(--cream);
    border-left: 4px solid var(--yellow);
    padding: 12px 16px;
    border-radius: 0 12px 12px 0;
  }
  .value-icon { font-size: 1.4rem; flex-shrink: 0; }
  .value-text { font-size: .95rem; line-height: 1.6; color: var(--brown-m); }
  .value-text strong { color: var(--brown); }

  /* ── PRODUK ── */
  #produk { background: var(--cream); }
  .produk-wrap { max-width: 1100px; margin: 0 auto; }
  .produk-intro { max-width: 680px; margin: 0 auto 50px; text-align: center; }
  .produk-cards {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 28px;
  }
  .card {
    background: var(--white);
    border-radius: 24px;
    border: 2.5px solid transparent;
    box-shadow: 4px 4px 0 rgba(61,28,2,.1);
    overflow: hidden;
    transition: transform .2s, box-shadow .2s, border-color .2s;
  }
  .card:hover { transform: translateY(-6px); box-shadow: 6px 10px 0 rgba(61,28,2,.15); border-color: var(--yellow); }
  .card-img {
    height: 180px;
    display: flex; align-items: center; justify-content: center;
    font-size: 5rem;
    position: relative;
  }
  .card-img.original { background: linear-gradient(135deg, #FFF9C4, #FFD54F); }
  .card-img.coklat   { background: linear-gradient(135deg, #D7CCC8, #A1887F); }
  .card-badge {
    position: absolute; top: 12px; right: 12px;
    background: var(--orange);
    color: white; font-weight: 800; font-size: .75rem;
    padding: 4px 10px; border-radius: 100px;
  }
  .card-body { padding: 22px 24px 28px; }
  .card-name {
    font-family: 'Fredoka One', cursive;
    font-size: 1.5rem; color: var(--brown);
    margin-bottom: 6px;
  }
  .card-rasa {
    font-size: .8rem; font-weight: 700; letter-spacing: 1px;
    text-transform: uppercase; color: var(--orange);
    margin-bottom: 10px;
  }
  .card-desc { font-size: .9rem; line-height: 1.65; color: var(--brown-m); margin-bottom: 18px; }
  .card-price {
    font-family: 'Fredoka One', cursive;
    font-size: 2rem; color: var(--brown);
  }
  .card-price span { font-size: 1rem; font-family: 'Nunito', sans-serif; color: var(--brown-m); }

  /* ── FILOSOFI ── */
  #filosofi {
    background: var(--brown);
    color: var(--cream);
  }
  #filosofi .sec-title { color: var(--yellow); }
  #filosofi .sec-label { color: var(--orange); }
  .fil-grid {
    max-width: 1100px; margin: 0 auto;
    display: grid; grid-template-columns: 1fr 1fr; gap: 50px;
    align-items: center;
  }
  .fil-cards { display: flex; flex-direction: column; gap: 18px; }
  .fil-card {
    background: rgba(255,255,255,.05);
    border: 1.5px solid rgba(245,197,24,.3);
    border-radius: 18px; padding: 22px 24px;
  }
  .fil-card h3 {
    font-family: 'Fredoka One', cursive;
    font-size: 1.3rem; color: var(--yellow);
    margin-bottom: 8px;
    display: flex; align-items: center; gap: 10px;
  }
  .fil-card p { font-size: .9rem; line-height: 1.7; color: rgba(255,248,231,.8); }
  .fil-visual {
    text-align: center;
    font-size: 7rem;
    animation: float 4s ease-in-out infinite 1s;
  }
  .fil-quote {
    font-family: 'Fredoka One', cursive;
    font-size: 1.6rem; color: var(--yellow);
    margin-top: 20px; line-height: 1.3;
  }

  /* ── KONTAK ── */
  #kontak { background: var(--white); }
  .kontak-wrap {
    max-width: 900px; margin: 0 auto;
    display: grid; grid-template-columns: 1fr 1fr; gap: 50px;
    align-items: start;
  }
  .kontak-info { display: flex; flex-direction: column; gap: 16px; margin-top: 24px; }
  .kontak-item {
    display: flex; align-items: flex-start; gap: 14px;
    padding: 16px 18px;
    background: var(--cream);
    border-radius: 14px;
    border: 1.5px solid #EEE5D0;
    transition: border-color .2s;
  }
  .kontak-item:hover { border-color: var(--yellow); }
  .kontak-icon { font-size: 1.5rem; flex-shrink: 0; }
  .kontak-detail strong { display: block; font-size: .8rem; letter-spacing: 1px; text-transform: uppercase; color: var(--orange); margin-bottom: 3px; }
  .kontak-detail p { font-size: .95rem; color: var(--brown-m); line-height: 1.5; }
  .kontak-detail a { color: var(--brown-m); text-decoration: none; }
  .kontak-detail a:hover { color: var(--orange); }
  .kontak-cta {
    background: linear-gradient(145deg, #FFECB3, #FFE082);
    border-radius: 20px;
    border: 2.5px solid var(--yellow-d);
    padding: 32px 28px;
    box-shadow: 4px 4px 0 var(--brown);
    text-align: center;
  }
  .kontak-cta .emoji { font-size: 3.5rem; margin-bottom: 12px; }
  .kontak-cta h3 {
    font-family: 'Fredoka One', cursive;
    font-size: 1.6rem; color: var(--brown);
    margin-bottom: 10px;
  }
  .kontak-cta p { font-size: .9rem; color: var(--brown-m); margin-bottom: 22px; line-height: 1.6; }
  .btn-wa {
    display: inline-flex; align-items: center; gap: 8px;
    background: #25D366; color: white;
    font-family: 'Fredoka One', cursive; font-size: 1.1rem;
    padding: 13px 28px; border-radius: 50px;
    text-decoration: none;
    box-shadow: 3px 3px 0 var(--brown);
    transition: transform .15s, box-shadow .15s;
  }
  .btn-wa:hover { transform: translate(-2px,-2px); box-shadow: 5px 5px 0 var(--brown); }

  /* ── FOOTER ── */
  footer {
    background: var(--brown);
    color: rgba(255,248,231,.6);
    text-align: center;
    padding: 28px 20px;
    font-size: .85rem;
  }
  footer strong { color: var(--yellow); }

  /* ── RESPONSIVE ── */
  @media (max-width: 768px) {
    nav { padding: 12px 20px; }
    .nav-links { gap: 16px; }
    .nav-links a { font-size: .8rem; }
    .hero { padding: 100px 20px 50px; }
    .hero-inner, .about-grid, .fil-grid, .kontak-wrap {
      grid-template-columns: 1fr;
      gap: 36px;
    }
    .hero-visual { order: -1; }
    .banana-emoji-big { font-size: 6rem; }
    section { padding: 60px 20px; }
    .hero-badge.bottom-left { display: none; }
  }
</style>
</head>
